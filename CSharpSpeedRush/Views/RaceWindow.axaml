<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSharpSpeedRush.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="660"
        x:Class="CSharpSpeedRush.Views.RaceWindow"
        x:DataType="vm:RaceWindowViewModel"
        Title="Race — C# Speed Rush"
        Width="900" Height="660"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        CanResize="False">

    <!--
        Design.DataContext omitted: RaceWindowViewModel requires a RaceManager
        constructor argument and is set at runtime from CarSelectionViewModel.
    -->

    <!-- Root grid: layer 0 = race HUD, layer 1 = end-of-race overlay -->
    <Grid>

    <!-- ═══ HUD LAYER ═══ -->
    <Grid RowDefinitions="80,*,44">

        <!-- RACE HEADER: Lap | Fuel | Time -->
        <Border Grid.Row="0" Background="#171717"
                BorderThickness="0,0,0,1" BorderBrush="#2A2A2A">
            <Grid ColumnDefinitions="240,*,*" Margin="0,0,0,0">

                <!-- Current lap -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="24,0,0,0">
                    <TextBlock Text="{Binding LapDisplay}"
                               FontSize="32" FontWeight="Black" LetterSpacing="2"
                               Foreground="White"/>
                    <TextBlock Text="Grand Circuit" FontSize="9"
                               Foreground="#3A3A3A" Margin="2,2,0,0"/>
                </StackPanel>

                <!-- Fuel level -->
                <Grid Grid.Column="1" RowDefinitions="Auto,6,Auto" Margin="16,0,16,0"
                      VerticalAlignment="Center">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <material:MaterialIcon Kind="FuelPump" Width="13" Height="13"
                                               Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="Fuel" FontSize="10" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding FuelPercentage, StringFormat='{}{0:F0}%'}"
                                   FontSize="10" FontWeight="Bold" Foreground="White"
                                   Margin="4,0,0,0"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="2" Value="{Binding FuelLevel}" Minimum="0" Maximum="100"
                                 Height="6" Foreground="#C5C8FF" Background="#1E1E2E" CornerRadius="1"/>
                </Grid>

                <!-- Time remaining -->
                <Grid Grid.Column="2" RowDefinitions="Auto,6,Auto" Margin="16,0,24,0"
                      VerticalAlignment="Center">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                        <material:MaterialIcon Kind="Stopwatch" Width="13" Height="13"
                                               Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="Time" FontSize="10" FontWeight="Bold"
                                   Foreground="#888888" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding TimeRemaining, StringFormat='{}{0:F0}s'}"
                                   FontSize="10" FontWeight="Bold" Foreground="White"
                                   Margin="4,0,0,0"/>
                    </StackPanel>
                    <ProgressBar Grid.Row="2" Value="{Binding TimePercentage}" Minimum="0" Maximum="100"
                                 Height="6" Foreground="#4466FF" Background="#0D0D2A" CornerRadius="1"/>
                </Grid>

            </Grid>
        </Border>

        <!-- CONTENT ROW: Event log | Center | Action buttons -->
        <Grid Grid.Row="1" ColumnDefinitions="220,*,200">

            <!-- EVENT LOG -->
            <Border Grid.Column="0" Background="#191919"
                    BorderThickness="0,0,1,0" BorderBrush="#252525"
                    Padding="18,18,18,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,14">
                        <material:MaterialIcon Kind="ClipboardList" Width="12" Height="12"
                                               Foreground="#FF6B5B" VerticalAlignment="Center"/>
                        <TextBlock Text="Event Log" FontSize="10" FontWeight="Bold"
                                   Foreground="#FF6B5B" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding EventLogDisplay}"
                               FontFamily="Courier New,Consolas,monospace"
                               FontSize="11" LineHeight="20"
                               Foreground="#555555" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CENTER: Status + progress indicator -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="28,0,28,0" Spacing="16">

                <TextBlock Text="{Binding SpeedStatus}"
                           FontSize="12" FontWeight="Bold"
                           Foreground="#444444" HorizontalAlignment="Center"
                           TextWrapping="Wrap" TextAlignment="Center"/>

                <TextBlock Text="{Binding ProgressBarDisplay}"
                           FontFamily="Courier New,Consolas,monospace"
                           FontSize="16" Foreground="#4466FF"
                           HorizontalAlignment="Center"/>

            </StackPanel>

            <!-- ACTION BUTTONS -->
            <Border Grid.Column="2" Background="#191919"
                    BorderThickness="1,0,0,0" BorderBrush="#252525"
                    Padding="14,18,14,18">
                <StackPanel Spacing="8">

                    <TextBlock Text="Actions" FontSize="9" FontWeight="Bold"
                               Foreground="#3A3A3A" Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>

                    <!-- Speed Up -->
                    <Button Command="{Binding SpeedUpCommand}"
                            IsEnabled="{Binding SpeedUpEnabled}"
                            Background="#FF5545"
                            Height="110" CornerRadius="2" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <material:MaterialIcon Kind="FlashOn" Width="24" Height="24"
                                                   Foreground="#1C1C1C" HorizontalAlignment="Center"/>
                            <TextBlock Text="SPEED UP" FontSize="14" FontWeight="Black"
                                       LetterSpacing="1" Foreground="#1C1C1C"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Maintain Speed -->
                    <Button Command="{Binding MaintainSpeedCommand}"
                            IsEnabled="{Binding MaintainEnabled}"
                            Background="#4466FF"
                            Height="110" CornerRadius="2" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <material:MaterialIcon Kind="ArrowRightBold" Width="24" Height="24"
                                                   Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="MAINTAIN" FontSize="14" FontWeight="Black"
                                       LetterSpacing="1" Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Pit Stop -->
                    <Button Command="{Binding PitStopCommand}"
                            IsEnabled="{Binding PitStopEnabled}"
                            Background="#9999CC"
                            Height="110" CornerRadius="2" Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center">
                        <StackPanel Spacing="6" HorizontalAlignment="Center">
                            <material:MaterialIcon Kind="Tools" Width="24" Height="24"
                                                   Foreground="#1C1C1C" HorizontalAlignment="Center"/>
                            <TextBlock Text="PIT STOP" FontSize="14" FontWeight="Black"
                                       LetterSpacing="1" Foreground="#1C1C1C"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </Border>

        </Grid>

        <!-- STATUS BAR -->
        <Border Grid.Row="2" Background="#131313"
                BorderThickness="0,1,0,0" BorderBrush="#252525"
                Padding="24,0">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="11" Foreground="#555555"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Border>

    </Grid>

    <!-- ═══ END-OF-RACE OVERLAY ═══ -->
    <Border IsVisible="{Binding RaceOver}"
            Background="#E6131313"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
        <Grid ColumnDefinitions="*,Auto,*" RowDefinitions="*,Auto,*">

            <Border Grid.Column="1" Grid.Row="1"
                    Background="#1E1E1E"
                    BorderBrush="#2A2A2A" BorderThickness="1"
                    CornerRadius="3" MinWidth="660"
                    Padding="50,44,50,44">
                <Grid ColumnDefinitions="*,48,240">

                    <!-- Outcome text + stats -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">

                        <!-- Victory icon + tag -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16"
                                    IsVisible="{Binding IsVictory}">
                            <material:MaterialIcon Kind="Trophy" Width="22" Height="22" Foreground="#FF9900"/>
                            <Border Background="#FF5545" CornerRadius="2" Padding="10,4">
                                <TextBlock Text="Race Complete" FontSize="10" FontWeight="Bold"
                                           Foreground="#1C1C1C"/>
                            </Border>
                        </StackPanel>

                        <!-- Loss icon + tag -->
                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,0,0,16"
                                    IsVisible="{Binding !IsVictory}">
                            <material:MaterialIcon Kind="FlagRemove" Width="22" Height="22" Foreground="#FF6B5B"/>
                            <Border Background="#333333" CornerRadius="2" Padding="10,4">
                                <TextBlock Text="Race Over" FontSize="10" FontWeight="Bold"
                                           Foreground="#888888"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="{Binding OutcomeHeadline}"
                                   FontSize="48" FontWeight="Black"
                                   LetterSpacing="2" Foreground="#FF6B5B"
                                   TextWrapping="Wrap" Margin="0,0,0,24"/>

                        <TextBlock Text="{Binding OutcomeDetail}"
                                   FontFamily="Courier New,Consolas,monospace"
                                   FontSize="13" LineHeight="26"
                                   Foreground="#666666"/>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Grid.Column="1" Width="1" Background="#2A2A2A"
                            VerticalAlignment="Stretch" HorizontalAlignment="Center"/>

                    <!-- Back to menu -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Button Command="{Binding BackToMenuCommand}"
                                Background="#FF6B5B"
                                Height="56" CornerRadius="2" Cursor="Hand"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <material:MaterialIcon Kind="HomeVariant" Width="18" Height="18"
                                                       Foreground="#1C1C1C" VerticalAlignment="Center"/>
                                <TextBlock Text="Back to Menu" FontSize="13" FontWeight="Black"
                                           Foreground="#1C1C1C" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

        </Grid>
    </Border>

    </Grid>
</Window>
