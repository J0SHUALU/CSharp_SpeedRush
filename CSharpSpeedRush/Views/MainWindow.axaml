<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSharpSpeedRush.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="560"
        x:Class="CSharpSpeedRush.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="C# Speed Rush"
        Width="800" Height="560"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto,*">

        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Spacing="0">

            <!-- Flag icon + accent bar -->
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,20">
                <material:MaterialIcon Kind="FlagCheckered" Width="28" Height="28" Foreground="#FF6B5B"/>
                <Border Height="3" Width="60" Background="#FF6B5B" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Text="C# SPEED" FontSize="64" FontWeight="Black"
                       LetterSpacing="3" Foreground="#FF6B5B" LineHeight="72"/>
            <TextBlock Text="RUSH" FontSize="64" FontWeight="Black"
                       LetterSpacing="3" Foreground="White" LineHeight="72"
                       Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Tagline}"
                       FontSize="13" Foreground="#555555"
                       HorizontalAlignment="Left"
                       Margin="0,0,0,36"/>

            <Grid ColumnDefinitions="*,4,*" Width="460">

                <Button Grid.Column="0"
                        Command="{Binding StartRaceCommand}"
                        Background="#FF6B5B"
                        Height="80" CornerRadius="2" Cursor="Hand"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <material:MaterialIcon Kind="PlayCircle" Width="22" Height="22" Foreground="#1C1C1C" VerticalAlignment="Center"/>
                        <TextBlock Text="START RACE" FontSize="16" FontWeight="Black"
                                   LetterSpacing="2" Foreground="#1C1C1C" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Command="{Binding QuitCommand}"
                        Background="#4466FF"
                        Height="80" CornerRadius="2" Cursor="Hand"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                        <material:MaterialIcon Kind="ExitToApp" Width="22" Height="22" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="QUIT" FontSize="16" FontWeight="Black"
                                   LetterSpacing="2" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

            </Grid>

        </StackPanel>

    </Grid>
</Window>
