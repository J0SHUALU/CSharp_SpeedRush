<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSharpSpeedRush.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="620" d:DesignHeight="440"
        x:Class="CSharpSpeedRush.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="C# Speed Rush"
        Width="620" Height="440"
        WindowStartupLocation="CenterScreen"
        Background="#080812"
        CanResize="False">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="6,*,Auto">

        <!-- Neon top stripe -->
        <Border Grid.Row="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                    <GradientStop Color="#FF0055" Offset="0"/>
                    <GradientStop Color="#FF6600" Offset="0.5"/>
                    <GradientStop Color="#FF0055" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Centre content -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="0">

            <material:MaterialIcon Kind="CarSports"
                                   Width="72" Height="72"
                                   Foreground="#FF0055"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>

            <TextBlock Text="C# SPEED RUSH"
                       FontSize="42" FontWeight="Black"
                       LetterSpacing="5"
                       Foreground="White"
                       HorizontalAlignment="Center"/>

            <Border Height="3" Width="320" CornerRadius="2" Margin="0,6,0,8">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="Transparent" Offset="0"/>
                        <GradientStop Color="#FF0055" Offset="0.4"/>
                        <GradientStop Color="#FF6600" Offset="0.6"/>
                        <GradientStop Color="Transparent" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <TextBlock Text="{Binding Tagline}"
                       FontSize="13" LetterSpacing="2"
                       Foreground="#445566"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,44"/>

            <Button HorizontalContentAlignment="Center" Command="{Binding StartRaceCommand}"
                    HorizontalAlignment="Center"
                    Width="260" Height="56"
                    CornerRadius="5"
                    Margin="0,0,0,14"
                    Cursor="Hand">
                <Button.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                        <GradientStop Color="#CC0044" Offset="0"/>
                        <GradientStop Color="#FF0055" Offset="1"/>
                    </LinearGradientBrush>
                </Button.Background>
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <material:MaterialIcon Kind="PlayCircle" Width="26" Height="26" Foreground="White"/>
                    <TextBlock Text="START RACE"
                               FontSize="18" FontWeight="Black"
                               LetterSpacing="3" Foreground="White"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button HorizontalContentAlignment="Center" Command="{Binding QuitCommand}"
                    HorizontalAlignment="Center"
                    Width="260" Height="44"
                    CornerRadius="5"
                    Background="#10101E"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <material:MaterialIcon Kind="ExitToApp" Width="20" Height="20" Foreground="#445566"/>
                    <TextBlock Text="QUIT" FontSize="14" FontWeight="Bold"
                               LetterSpacing="3" Foreground="#445566"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>

        <TextBlock Grid.Row="2"
                   Text="5 LAPS  ·  3 CARS  ·  300 SECONDS"
                   FontSize="10" LetterSpacing="2"
                   Foreground="#223344"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,16"/>
    </Grid>
</Window>
