<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:CSharpSpeedRush.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="680"
        x:Class="CSharpSpeedRush.Views.CarSelectionWindow"
        x:DataType="vm:CarSelectionViewModel"
        Title="Select Your Car — C# Speed Rush"
        Width="900" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#1C1C1C"
        CanResize="False">

    <Design.DataContext>
        <vm:CarSelectionViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,80">

        <!-- HEADER -->
        <StackPanel Grid.Row="0" Margin="40,32,40,24">
            <TextBlock Text="CHOOSE YOUR MACHINE" FontSize="28" FontWeight="Black"
                       LetterSpacing="3" Foreground="White"/>
            <Border Height="3" Width="60" Background="#FF6B5B"
                    HorizontalAlignment="Left" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- CAR CARDS -->
        <Grid Grid.Row="1" ColumnDefinitions="*,10,*,10,*" Margin="40,0,40,0">

            <!-- ═══ SPORTS CAR ═══ -->
            <Border Grid.Column="0"
                    BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="3" Cursor="Hand">
                <Grid>
                    <Border Background="#1E1E1E" CornerRadius="3" IsVisible="{Binding !SportsCarSelected}"/>
                    <Border Background="#1A1A50" CornerRadius="3" IsVisible="{Binding SportsCarSelected}"/>
                    <Button Background="Transparent" BorderThickness="0"
                            Command="{Binding SelectSportsCarCommand}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top"
                            Padding="20,20,20,20">
                        <StackPanel>
                            <TextBlock Text="ID 001" FontSize="9" LetterSpacing="3"
                                       Foreground="#444444" Margin="0,0,0,8"/>
                            <material:MaterialIcon Kind="CarSports" Width="36" Height="36"
                                                   Foreground="#FF6B5B" HorizontalAlignment="Left"
                                                   Margin="0,0,0,8"/>
                            <TextBlock Text="SPORTS CAR" FontSize="20" FontWeight="Black"
                                       LetterSpacing="1" Foreground="White" Margin="0,0,0,20"/>
                            <StackPanel Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="Max Speed"     FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="220 KM/H"     FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Capacity" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="60 L"         FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Per Turn" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="4.5 L"        FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    BorderThickness="1" BorderBrush="#303030" CornerRadius="2"
                                    IsVisible="{Binding !SportsCarSelected}">
                                <TextBlock Text="Select" FontSize="11" FontWeight="Bold"
                                           Foreground="#555555" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    Background="#4466FF" CornerRadius="2"
                                    IsVisible="{Binding SportsCarSelected}">
                                <TextBlock Text="Selected" FontSize="11" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ ECO CAR ═══ -->
            <Border Grid.Column="2"
                    BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="3" Cursor="Hand">
                <Grid>
                    <Border Background="#1E1E1E" CornerRadius="3" IsVisible="{Binding !EcoCarSelected}"/>
                    <Border Background="#1A1A50" CornerRadius="3" IsVisible="{Binding EcoCarSelected}"/>
                    <Button Background="Transparent" BorderThickness="0"
                            Command="{Binding SelectEcoCarCommand}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top"
                            Padding="20,20,20,20">
                        <StackPanel>
                            <TextBlock Text="ID 002" FontSize="9" LetterSpacing="3"
                                       Foreground="#444444" Margin="0,0,0,8"/>
                            <material:MaterialIcon Kind="CarSports" Width="36" Height="36"
                                                   Foreground="#00CC88" HorizontalAlignment="Left"
                                                   Margin="0,0,0,8"/>
                            <TextBlock Text="ECO CAR" FontSize="20" FontWeight="Black"
                                       LetterSpacing="1" Foreground="White" Margin="0,0,0,20"/>
                            <StackPanel Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="Max Speed"     FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="160 KM/H"     FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Capacity" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="45 L"         FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Per Turn" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="2.0 L"        FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    BorderThickness="1" BorderBrush="#303030" CornerRadius="2"
                                    IsVisible="{Binding !EcoCarSelected}">
                                <TextBlock Text="Select" FontSize="11" FontWeight="Bold"
                                           Foreground="#555555" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    Background="#4466FF" CornerRadius="2"
                                    IsVisible="{Binding EcoCarSelected}">
                                <TextBlock Text="Selected" FontSize="11" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- ═══ MUSCLE CAR ═══ -->
            <Border Grid.Column="4"
                    BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="3" Cursor="Hand">
                <Grid>
                    <Border Background="#1E1E1E" CornerRadius="3" IsVisible="{Binding !MuscleCarSelected}"/>
                    <Border Background="#1A1A50" CornerRadius="3" IsVisible="{Binding MuscleCarSelected}"/>
                    <Button Background="Transparent" BorderThickness="0"
                            Command="{Binding SelectMuscleCarCommand}"
                            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch" VerticalContentAlignment="Top"
                            Padding="20,20,20,20">
                        <StackPanel>
                            <TextBlock Text="ID 003" FontSize="9" LetterSpacing="3"
                                       Foreground="#444444" Margin="0,0,0,8"/>
                            <material:MaterialIcon Kind="CarSports" Width="36" Height="36"
                                                   Foreground="#FF9900" HorizontalAlignment="Left"
                                                   Margin="0,0,0,8"/>
                            <TextBlock Text="MUSCLE CAR" FontSize="20" FontWeight="Black"
                                       LetterSpacing="1" Foreground="White" Margin="0,0,0,20"/>
                            <StackPanel Spacing="12">
                                <StackPanel>
                                    <TextBlock Text="Max Speed"     FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="200 KM/H"     FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Capacity" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="70 L"         FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Fuel Per Turn" FontSize="9"  Foreground="#555555"/>
                                    <TextBlock Text="6.0 L"        FontSize="15" FontWeight="Bold" Foreground="White" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    BorderThickness="1" BorderBrush="#303030" CornerRadius="2"
                                    IsVisible="{Binding !MuscleCarSelected}">
                                <TextBlock Text="Select" FontSize="11" FontWeight="Bold"
                                           Foreground="#555555" HorizontalAlignment="Center"/>
                            </Border>
                            <Border Margin="0,20,0,0" Padding="0,10"
                                    Background="#4466FF" CornerRadius="2"
                                    IsVisible="{Binding MuscleCarSelected}">
                                <TextBlock Text="Selected" FontSize="11" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"/>
                            </Border>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

        </Grid>

        <!-- BOTTOM BAR -->
        <Grid Grid.Row="2" ColumnDefinitions="Auto,*,Auto"
              Margin="40,0,40,0" VerticalAlignment="Center">

            <Button Grid.Column="0"
                    Width="120" Height="44" CornerRadius="2"
                    Background="#1E1E1E" Cursor="Hand"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="BackButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <material:MaterialIcon Kind="ArrowBack" Width="16" Height="16"
                                           Foreground="#555555" VerticalAlignment="Center"/>
                    <TextBlock Text="Back" FontSize="12" FontWeight="Bold"
                               Foreground="#555555" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2"
                    Command="{Binding StartRaceCommand}"
                    IsEnabled="{Binding SelectedCar, Converter={x:Static ObjectConverters.IsNotNull}}"
                    Background="#FF6B5B"
                    Width="200" Height="44"
                    CornerRadius="2" Cursor="Hand"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                    <material:MaterialIcon Kind="RocketLaunch" Width="18" Height="18"
                                           Foreground="#1C1C1C" VerticalAlignment="Center"/>
                    <TextBlock Text="START RACE" FontSize="13" FontWeight="Black"
                               LetterSpacing="2" Foreground="#1C1C1C" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

        </Grid>

    </Grid>
</Window>
